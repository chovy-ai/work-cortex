{
  "id": "event-knowledge",
  "description": "应用事件目录（名称/参数/上报时机）",
  "truth_source": "应用源码（仓库见 app.config.json 的 app.repo）",
  "serves": [
    "knowledge-store/event-catalog.json"
  ],
  "update": {
    "type": "script",
    "cmd": "bash domains/event-knowledge/sync_app.sh && node build/domains/event-knowledge/extract_events.js"
  },
  "check": {
    "type": "script",
    "cmd": "node build/domains/knowledge-update/check_freshness.js event-knowledge",
    "stale_after_hours": 24
  },
  "doc_links": []
}
