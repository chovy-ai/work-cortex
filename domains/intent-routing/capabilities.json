{
  "version": 1,
  "categories": [
    {
      "category": "aggregate_analysis",
      "datafinder_area": "查询分析",
      "purpose": "Compute aggregate metrics, trends, breakdowns, and analysis results."
    },
    {
      "category": "asset_reuse",
      "datafinder_area": "看板与报表",
      "purpose": "Reuse existing DataFinder dashboards and report definitions."
    },
    {
      "category": "user_level_query",
      "datafinder_area": "用户分析、分群、用户标签",
      "purpose": "Query one user/device, user lists, segments, and tags."
    },
    {
      "category": "raw_diagnostics",
      "datafinder_area": "原始事件导出、用户属性导出、数据治理/Kafka、元数据",
      "purpose": "Inspect raw data, metadata, ingestion quality, and custom extracts."
    }
  ],
  "capabilities": [
    {
      "category": "aggregate_analysis",
      "capability_id": "datafinder.openapi.analysis_query",
      "status": "available_after_config",
      "datafinder_area": "查询分析",
      "supported_intents": [
        "metric_trend",
        "metric_breakdown",
        "event_usage"
      ],
      "templates": [
        "analysis.dau_trend",
        "analysis.metric_trend",
        "analysis.metric_breakdown",
        "analysis.event_usage"
      ],
      "required_slots": [
        "app_id",
        "metric",
        "time_range",
        "granularity"
      ],
      "optional_slots": [
        "identity",
        "filters",
        "breakdowns",
        "timezone",
        "event_set"
      ],
      "constraints": {
        "requires_openapi_config": true,
        "supports_raw_events": false,
        "supports_large_export": false,
        "supports_existing_dashboard_assets": false
      },
      "output": "aggregate_table",
      "fallback_capabilities": [
        "datafinder.openapi.analysis_download",
        "datafinder.kafka.behavior_event"
      ],
      "unsupported_when": [
        "request requires raw event payload fields",
        "request requires existing dashboard/report parity",
        "result exceeds normal query row limits"
      ]
    },
    {
      "category": "aggregate_analysis",
      "capability_id": "datafinder.openapi.analysis_result",
      "status": "available_after_config",
