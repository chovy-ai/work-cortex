{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://nextop.local/schemas/query-plan.schema.json",
  "title": "Nextop Data Analytics QueryPlan",
  "type": "object",
  "required": [
    "status",
    "plan_id",
    "source",
    "category",
    "intent",
    "capability_id",
    "template_id",
    "compiler",
    "warnings"
  ],
  "properties": {
    "status": {
      "type": "string",
      "enum": ["ready", "blocked"]
    },
    "plan_id": {
      "type": "string"
    },
    "source": {
      "type": "string",
      "enum": ["datafinder_openapi", "datafinder_kafka", "local_file"]
    },
    "category": {
      "type": "string",
      "enum": ["aggregate_analysis", "asset_reuse", "user_level_query", "raw_diagnostics"]
    },
    "intent": {
      "type": "string"
    },
    "capability_id": {
      "type": "string"
    },
    "template_id": {
      "type": "string"
    },
    "compiler": {
      "type": "string",
      "enum": [
        "datafinder.analysis",
        "datafinder.asset",
        "datafinder.user",
        "datafinder.diagnostics",
        "datafinder.kafka",
        "local.file"
      ]
    },
    "blocked_reason": {
      "type": "string",
      "enum": [
        "missing_config",
        "missing_metadata",
        "ambiguous_field",
        "unresolved_time_range",
        "unsupported_template",
        "missing_local_file"
      ]
    },
    "required_to_unblock": {
      "type": "array",
      "items": { "type": "string" }
    },
    "app": {
      "type": "object",
      "properties": {
        "app_id": { "type": ["integer", "string"] },
        "timezone": { "type": "string" },
        "tenant_id": { "type": ["integer", "string"] },
        "project_id_or_header": { "type": ["integer", "string", "object"] }
      },
      "additionalProperties": false
    },
    "time": {
      "type": "object",
      "required": ["input"],
      "properties": {
        "input": { "type": ["string", "object"] },
        "resolved": {
          "type": "object",
          "required": ["start", "end", "timezone", "granularity"],
          "properties": {
            "start": { "type": "string" },
            "end": { "type": "string" },
            "timezone": { "type": "string" },
            "granularity": {
              "type": "string",
              "enum": ["hour", "day", "week", "month"]
            }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },
    "metric_definition": {
      "type": "object",
      "required": ["metric", "aggregation"],
      "properties": {
        "metric": { "type": "string" },
        "aggregation": {
          "type": "string",
          "enum": ["count", "count_distinct", "sum", "avg", "ratio", "custom"]
        },
        "field": { "type": "string" },
        "numerator": { "type": "object" },
        "denominator": { "type": "object" },
        "event_set": {
          "type": "array",
          "items": { "type": "string" }
        }
      },
      "additionalProperties": false
    },
    "dimensions": {
      "type": "object",
      "properties": {
        "breakdowns": {
          "type": "array",
          "items": { "type": "string" }
        },
        "filters": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["field", "op", "value"],
            "properties": {
              "field": { "type": "string" },
              "op": { "type": "string" },
              "value": {}
            },
            "additionalProperties": false
          }
        }
      },
      "additionalProperties": false
    },
    "asset": {
      "type": "object",
      "properties": {
        "dashboard_id": { "type": "string" },
        "report_id": { "type": "string" },
        "keyword": { "type": "string" },
        "owner": { "type": "string" }
      },
      "additionalProperties": false
    },
    "user_lookup": {
      "type": "object",
      "properties": {
        "query_type": {
          "type": "string",
          "enum": ["user_unique_id", "ssid", "web_id", "device_id"]
        },
        "query_id": { "type": "string" },
        "timestamp": { "type": ["integer", "string"] },
        "orientation": {
          "type": "string",
          "enum": ["before", "after", "around"]
        },
        "count": { "type": "integer", "minimum": 1 }
      },
      "additionalProperties": false
    },
    "raw": {
      "type": "object",
      "properties": {
        "broker_or_zk": { "type": "string" },
        "topic": { "type": "string" },
        "consumer_group": { "type": "string" },
        "export_type": { "type": "string" },
        "metadata_type": { "type": "string" },
        "sample_limit": { "type": "integer", "minimum": 1 },
        "offset_policy": { "type": "string" },
        "fields": {
          "type": "array",
          "items": { "type": "string" }
        }
      },
      "additionalProperties": false
    },
    "local_file": {
      "type": "object",
      "properties": {
        "file_path": { "type": "string" },
        "schema_hint": { "type": "string" },
        "time_column": { "type": "string" },
        "identity_column": { "type": "string" }
      },
      "additionalProperties": false
    },
    "compiler_inputs": {
      "type": "object",
      "additionalProperties": true
    },
    "validation": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": [
          "check_app_id",
          "check_date_coverage",
          "check_empty_result",
          "check_identity_null_rate",
          "check_report_id",
          "check_row_limit",
          "check_user_identifier",
          "check_schema_parseability",
          "check_sample_size",
          "check_offset_or_range"
        ]
      }
    },
    "warnings": {
      "type": "array",
      "items": { "type": "string" }
    }
  },
  "allOf": [
    {
      "if": {
        "properties": { "status": { "const": "ready" } },
        "required": ["status"]
      },
      "then": {
        "required": ["compiler_inputs", "validation"]
      }
    },
    {
      "if": {
        "properties": { "status": { "const": "blocked" } },
        "required": ["status"]
      },
      "then": {
        "required": ["blocked_reason", "required_to_unblock"]
      }
    }
  ],
  "additionalProperties": false
}
