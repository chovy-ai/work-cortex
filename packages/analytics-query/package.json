{
  "name": "@workcortex/analytics-query",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "数据查询能力（验证驱动、从 0 打磨）：把查询意图变成 DataFinder SDK 调用并出数",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "verify": "npm run build && node dist/scripts/verify.js"
  },
  "engines": { "node": ">=20" },
  "dependencies": {
    "@workcortex/datafinder-sdk": "*"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "typescript": "^5.5.0"
  }
}
