{
  "schema_version": 1,
  "start": "understand",
  "steps": [
    { "id": "understand", "kind": "step", "label": "理解你的问题", "run": "domains/query-execution/steps/understand.ts" },
    { "id": "route", "kind": "step", "label": "选择查询路径", "run": "domains/query-execution/steps/route.ts" },
    { "id": "dashboard.resolve", "kind": "step", "label": "定位对应报表", "run": "domains/query-execution/steps/dashboard/resolve.ts" },
    { "id": "dashboard.plan", "kind": "step", "label": "编排查询计划", "run": "domains/query-execution/steps/dashboard/plan.ts" },
    { "id": "dashboard.compile", "kind": "step", "label": "生成查询请求", "run": "domains/query-execution/steps/dashboard/compile.ts" },
    { "id": "dashboard.execute", "kind": "step", "label": "拉取报表数据", "run": "domains/query-execution/steps/dashboard/execute.ts" },
    { "id": "dashboard.report", "kind": "terminal", "label": "整理分析结论", "run": "domains/query-execution/steps/dashboard/report.ts" },
    { "id": "raw.prepare", "kind": "step", "label": "确认口径与数据源", "run": "domains/query-execution/steps/raw-analysis/prepare.ts" },
    { "id": "raw.auto_review", "kind": "gate", "label": "自检分析方案", "run": "domains/query-execution/steps/raw-analysis/auto_review.ts" },
    { "id": "raw.user_review", "kind": "human_gate", "label": "等待你确认方案", "run": "domains/query-execution/steps/raw-analysis/user_review.ts" },
    { "id": "raw.plan", "kind": "step", "label": "编排查询计划", "run": "domains/query-execution/steps/raw-analysis/plan.ts" },
    { "id": "raw.compile", "kind": "step", "label": "生成查询请求", "run": "domains/query-execution/steps/raw-analysis/compile.ts" },
    { "id": "raw.execute", "kind": "step", "label": "执行原始事件查询", "run": "domains/query-execution/steps/raw-analysis/execute.ts" },
    { "id": "raw.validate", "kind": "gate", "label": "校验数据质量", "run": "domains/query-execution/steps/raw-analysis/validate.ts" },
    { "id": "raw.report", "kind": "terminal", "label": "整理分析结论", "run": "domains/query-execution/steps/raw-analysis/report.ts" }
  ],
  "edges": {
    "understand": { "next": "route" },
    "route": { "dashboard": "dashboard.resolve", "raw_analysis": "raw.prepare" },
    "dashboard.resolve": { "next": "dashboard.plan" },
    "dashboard.plan": { "next": "dashboard.compile" },
    "dashboard.compile": { "next": "dashboard.execute" },
    "dashboard.execute": { "next": "dashboard.report" },
    "raw.prepare": { "next": "raw.auto_review" },
    "raw.auto_review": { "approved": "raw.user_review" },
    "raw.user_review": { "confirmed": "raw.plan" },
    "raw.plan": { "next": "raw.compile" },
    "raw.compile": { "next": "raw.execute" },
    "raw.execute": { "next": "raw.validate" },
    "raw.validate": { "ok": "raw.report" }
  },
  "backEdges": {
    "raw.auto_review": { "requires_revision": "raw.prepare", "maxRevisions": 2 },
    "raw.user_review": { "changes": "understand", "maxRevisions": 2 },
    "raw.validate": { "fail": "raw.plan", "maxRevisions": 2 }
  }
}
