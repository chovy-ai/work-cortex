{
  "app": {
    "name": "your-app",
    "repo": {
      "url": "https://github.com/your-org/your-app",
      "localPath": "../your-app"
    }
  },
  "sources": {
    "events": {
      "tsReporters": "path/to/analytics/reporters",
      "goEvents": "path/to/reporter/events",
      "mainAnalytics": "path/to/main-process/analytics",
      "scope": {
        "ts": ["apps", "packages"],
        "go": ["services", "packages", "apps"]
      }
    },
    "dataModel": {
      "defaults": "path/to/app.defaults.json",
      "reporter": "path/to/reporter/tea_reporter.go",
      "trackingDoc": "path/to/analytics-tracking.md"
    }
  },
  "output": {
    "eventCatalog": "knowledge-store/event-catalog.json",
    "dataModel": "knowledge-store/data-model.json"
  }
}
