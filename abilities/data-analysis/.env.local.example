# DataFinder OpenAPI 凭据模板。
# 用法：复制为 .env.local 再填真值。  cp .env.local.example .env.local
# .env.local 已被 .gitignore 忽略，真实 AK/SK 不会进 git；本模板只放占位值，可提交。
# 读取入口：domains/datafinder-interface/client.ts -> loadConfigFromEnv()

# ── 必填 ───────────────────────────────────────────────────────────────────────
DATAFINDER_BASE_URL=https://analytics.volcengineapi.com   # OpenAPI 域名（按区域/环境换）
DATAFINDER_ACCESS_KEY=your-access-key                     # AK
DATAFINDER_SECRET_KEY=your-secret-key                     # SK
DATAFINDER_APP_ID=00000000                                # API app_id（你应用的 DataFinder appId）

# ── 选填（缺省走代码默认）─────────────────────────────────────────────────────
DATAFINDER_REGION=cn-north-1                              # 默认 cn-north-1
DATAFINDER_SERVICE=datafinder                             # 默认 datafinder

# ── 按需（用到对应链路再填）───────────────────────────────────────────────────
DATAFINDER_ENVIRONMENT=                                   # 环境标识（如 cloud-native / byteplus）
DATAFINDER_PROJECT_ID=                                    # 项目 ID
DATAFINDER_DASHBOARD_ID=                                  # dashboard 路径默认报表 ID
DATAFINDER_EVENT_ANALYSIS_ID=                             # 事件分析 ID
DATAFINDER_INGEST_BASE_URL=                               # 数据上报/采集域名
